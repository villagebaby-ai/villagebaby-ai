---
// 매거진 cover 이미지 — 실제 이미지 또는 pillar 색상 + 일러스트 mock
// villagebaby.kr/assets/img/ 의 기존 일러스트 자산 활용
interface Props {
  cover?: string;
  illust?: string;
  title: string;
  pillar: string;
  aspect?: '16-9' | '4-3' | '1-1' | '4-5';
  alt?: string;
}
const { cover, illust, title, pillar, aspect = '4-3', alt } = Astro.props;

const pillarPalette: Record<string, { bg: string; bgEnd: string; ink: string; label: string; defaultIllust: string }> = {
  pregnancy: { bg: '#FFF8F0', bgEnd: '#FFE0CC', ink: '#7A4228', label: '임신', defaultIllust: 'assets/img/pregnant-mom.png' },
  newborn:   { bg: '#EFF4FA', bgEnd: '#C9DCEF', ink: '#15518F', label: '신생아', defaultIllust: 'assets/img/baby-angel.png' },
  toddler:   { bg: '#F0FCF8', bgEnd: '#BFEBE0', ink: '#1F6B5A', label: '영유아', defaultIllust: 'assets/img/baby-laughing.png' },
  school:    { bg: '#F7F1FF', bgEnd: '#ECE0FF', ink: '#5B3A8E', label: '학동기', defaultIllust: 'assets/img/baby-bear-study.png' },
  teen:      { bg: '#F0F8FC', bgEnd: '#C9E2EE', ink: '#1F5470', label: '청소년기', defaultIllust: 'assets/img/baby-graduate.png' },
  case:      { bg: '#FFFBED', bgEnd: '#FFE4B5', ink: '#8B6914', label: '케이스', defaultIllust: 'assets/img/baby-wink.png' },
};
const palette = pillarPalette[pillar] ?? pillarPalette['pregnancy'];
const aspectMap = { '16-9': '16 / 9', '4-3': '4 / 3', '1-1': '1 / 1', '4-5': '4 / 5' };
const aspectVal = aspectMap[aspect];

const base = import.meta.env.BASE_URL;
// cover supports:
//  - http(s) URLs (e.g. Unsplash CDN)
//  - absolute local paths (/covers/foo.jpg)
//  - bare filenames (foo.jpg) — assumed under /public/covers/
const isHttp = !!cover && /^https?:\/\//i.test(cover);
const isReal = !!cover && (isHttp || /\.(jpg|jpeg|png|webp)(\?.*)?$/i.test(cover));
const coverSrc = !isReal
  ? ''
  : isHttp
    ? cover
    : cover.startsWith(base)
      ? cover
      : `${base.replace(/\/$/, '')}${cover.startsWith('/') ? cover : '/' + cover}`;
const illustSrc = illust ?? `${base}${palette.defaultIllust}`;
---
<figure class={`cover ${isReal ? 'cover-real' : 'cover-mock'}`} style={`--aspect:${aspectVal};--bg:${palette.bg};--bg-end:${palette.bgEnd};--ink:${palette.ink};`} aria-hidden={!isReal}>
  {isReal ? (
    <img src={coverSrc} alt={alt ?? title} loading="lazy" decoding="async" />
  ) : (
    <div class="mock-inner">
      <img class="mock-illust" src={illustSrc} alt="" loading="lazy" decoding="async" />
      <p class="mock-cat">{palette.label}</p>
    </div>
  )}
</figure>

<style>
  .cover {
    margin: 0;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: var(--aspect);
    background: var(--bg);
    display: block;
    position: relative;
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cover-mock {
    background: linear-gradient(135deg, var(--bg) 0%, var(--bg-end) 100%);
  }
  .mock-inner {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 18px;
  }
  .mock-illust {
    max-width: 55%;
    max-height: 70%;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 0.95;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.06));
  }
  .mock-cat {
    position: absolute;
    top: 14px;
    left: 14px;
    background: rgba(255,255,255,0.85);
    color: var(--ink);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    padding: 4px 10px;
    border-radius: 999px;
    backdrop-filter: blur(8px);
    text-transform: uppercase;
  }
</style>
