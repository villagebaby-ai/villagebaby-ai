---
import BaseLayout from '../layouts/BaseLayout.astro';
import CoverImage from '../components/CoverImage.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const all = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const pillars = [
  {
    slug: 'pregnancy', label: '태아', sub: 'Pregnancy',
    desc: '가입 골든타임, NT·양수검사 결과별 시나리오, 합병증 산모 케이스',
    active: true, cover: `${base}covers/pregnancy-card.jpg`,
  },
  {
    slug: 'newborn', label: '신생아', sub: 'Newborn',
    desc: '출산 직후 NICU·황달, 미숙아 보험, 태아보험 → 어린이보험 전환',
    active: false, cover: `${base}covers/newborn-card.jpg`,
  },
  {
    slug: 'toddler', label: '영유아', sub: 'Toddler',
    desc: '어린이보험 전환 시점, 자녀 실손, 응급실·입원 청구 절차',
    active: false, cover: undefined,
  },
  {
    slug: 'school', label: '초등', sub: 'School',
    desc: '학교폭력·운동·치아 특약, 사춘기 재설계 시점 가이드',
    active: false, cover: undefined,
  },
  {
    slug: 'case', label: '케이스', sub: 'Case',
    desc: '거절·재가입·조건부 승인 — 실제 가입 사례 모음',
    active: true, cover: undefined,
  },
];

// intent → 서브토픽 레이블 (홈 최신글 태그용)
function intentLabel(intent: string[]): string {
  if (intent.includes('timing')) return '가입시기';
  if (intent.includes('condition')) return '검사결과';
  if (intent.includes('rejection')) return '합병증';
  if (intent.includes('comparison')) return '특약분석';
  if (intent.includes('claim')) return '청구·보상';
  if (intent.includes('case-story')) return '케이스';
  return '가이드';
}

const homeJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://villagebaby.kr/magazine/#website',
      name: '베이비빌리 보험 매거진',
      url: 'https://villagebaby.kr/magazine/',
      inLanguage: 'ko-KR',
      publisher: {
        '@type': 'Organization',
        name: '베이비빌리',
        url: 'https://villagebaby.kr/',
        logo: { '@type': 'ImageObject', url: 'https://villagebaby.kr/logo.png' },
      },
      description: '태아·신생아·영유아·초등 보험 케이스와 이야기로 부모의 보험 결정을 돕는 매거진.',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '홈', item: 'https://villagebaby.kr/' },
        { '@type': 'ListItem', position: 2, name: '보험 매거진', item: 'https://villagebaby.kr/magazine/' },
      ],
    },
  ],
};
---
<BaseLayout
  title="베이비빌리 보험 매거진 — 케이스와 이야기로 보는 보험 결정"
  description="태아·신생아·영유아·초등. 부모의 보험 결정을 케이스 스토리와 핏체크 12문항 무료 진단으로 도와드리는 매거진이에요.">

  <script type="application/ld+json" slot="head" set:html={JSON.stringify(homeJsonLd)} />

  <style is:global>
    main { max-width: none !important; padding: 0 !important; }
  </style>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-kicker">BABYBILLY INSURANCE MAGAZINE</p>
      <h1>부모의 보험 결정을<br/><em>이야기로 정리해드려요.</em></h1>
      <p class="hero-lede">
        가입 시기, 검사 결과의 영향, 거절과 재가입 — 케이스 스토리와 진단 도구로
        의사결정의 흐름을 정리한 매거진이에요.
      </p>
      <div class="hero-cta">
        <a class="btn-primary" href={`${base}tools/fit-check/`}>핏체크 12문항 시작</a>
        <a class="btn-ghost" href={`${base}pregnancy/`}>태아 보기 →</a>
      </div>
    </div>
  </section>

  <!-- FITCHECK FEATURE -->
  <section class="section-wrap">
    <div class="inner">
      <a href={`${base}tools/fit-check/`} class="fitcheck-card">
        <div class="fc-body">
          <p class="fc-label">1순위 도구 · 2분 무료 진단</p>
          <p class="fc-title">태아보험 핏체크 12문항</p>
          <p class="fc-desc">
            임신 주차·검사 결과·가족력 등 12문항에 답하면 가입 가능성 점수,
            추천 시기, 주의 특약 3개를 정리해드려요.
          </p>
          <span class="fc-cta">진단 시작하기 →</span>
        </div>
        <div class="fc-illust" aria-hidden="true">
          <img src={`${base}assets/img/baby-medical.png`} alt="" loading="lazy" />
        </div>
      </a>
    </div>
  </section>

  <!-- PILLAR GRID -->
  <section class="section-wrap">
    <div class="inner">
      <div class="section-head">
        <h2 class="section-title">생애주기로 보기</h2>
        <p class="section-sub">임신부터 초등까지, 시기별로 정리해드려요</p>
      </div>
      <ul class="pillar-grid">
        {pillars.map((p) => (
          <li class={p.active ? '' : 'soon'}>
            {p.active ? (
              <a href={`${base}${p.slug}/`} class="pillar-card">
                <div class="pillar-cover">
                  <CoverImage cover={p.cover} title={p.label} pillar={p.slug} aspect="4-3" />
                </div>
                <div class="pillar-body">
                  <p class="pillar-en">{p.sub}</p>
                  <p class="pillar-label">{p.label}</p>
                  <p class="pillar-desc">{p.desc}</p>
                  <p class="pillar-link">바로가기 →</p>
                </div>
              </a>
            ) : (
              <div class="pillar-card">
                <div class="pillar-cover">
                  <CoverImage cover={p.cover} title={p.label} pillar={p.slug} aspect="4-3" />
                </div>
                <div class="pillar-body">
                  <p class="pillar-en">{p.sub}</p>
                  <p class="pillar-label">{p.label}</p>
                  <p class="pillar-desc">{p.desc}</p>
                  <p class="pillar-soon">준비 중</p>
                </div>
              </div>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- LATEST ARTICLES -->
  {all.length > 0 && (
    <section class="section-wrap">
      <div class="inner">
        <div class="section-head">
          <h2 class="section-title">최근 발행 글</h2>
          <a class="section-more" href={`${base}pregnancy/`}>전체 보기 →</a>
        </div>
        <ul class="article-rows">
          {all.slice(0, 6).map((a) => (
            <li class="row-item">
              <a href={`${base}${a.slug}/`} class="row-link">
                <span class="row-tag">{intentLabel(a.data.intent)}</span>
                <div class="row-body">
                  <p class="row-title">{a.data.title}</p>
                  <p class="row-desc">{a.data.description}</p>
                </div>
                <span class="row-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- CROSS-LINK -->
  <section class="section-wrap section-wrap--last">
    <div class="inner">
      <div class="cross-card">
        <p class="cross-label">함께 보면 좋은 곳</p>
        <h3>베이비빌리 보험 가이드</h3>
        <p class="cross-desc">매거진은 케이스와 이야기, 가이드는 보험 종류별 정보 정리. 두 곳을 함께 쓰시면 의사결정이 빨라요.</p>
        <div class="cross-chips">
          <a href="/guide/" class="chip">태아보험 가이드</a>
          <a href="/child/" class="chip">어린이보험 가이드</a>
          <a href="/cancer/" class="chip">암보험 가이드</a>
          <a href="/care/" class="chip">간병보험 가이드</a>
          <a href="/female/" class="chip">여성보험 가이드</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .inner { max-width: 1080px; margin: 0 auto; padding: 0 24px; }
    .section-wrap { padding: 56px 0 0; }
    .section-wrap--last { padding-bottom: 64px; }

    /* HERO */
    .hero {
      background: linear-gradient(180deg, #F0F5FF 0%, #FFFFFF 100%);
      border-bottom: 1px solid var(--gray-100);
      padding: 64px 24px 72px;
      text-align: center;
    }
    .hero-inner { max-width: 640px; margin: 0 auto; }
    .hero-kicker {
      font-size: 11px; font-weight: 700;
      letter-spacing: 0.16em; color: var(--blue-600);
      margin: 0 0 20px;
    }
    .hero h1 {
      font-size: clamp(28px, 5vw, 46px);
      font-weight: 700; line-height: 1.25;
      letter-spacing: -0.025em; color: var(--gray-900);
      margin: 0 0 18px;
    }
    .hero h1 em { font-style: italic; color: var(--blue-700); }
    .hero-lede {
      font-size: 16px; color: var(--gray-600);
      line-height: 1.85; margin: 0 0 28px;
    }
    .hero-cta { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; }
    .btn-primary {
      display: inline-block;
      background: var(--blue-700); color: #fff;
      padding: 13px 26px; border-radius: 999px;
      font-size: 15px; font-weight: 600;
      text-decoration: none;
      transition: background 0.15s, transform 0.15s;
    }
    .btn-primary:hover { background: var(--blue-800); transform: translateY(-1px); }
    .btn-ghost {
      display: inline-block;
      color: var(--gray-700); border: 1px solid var(--gray-300);
      padding: 13px 22px; border-radius: 999px;
      font-size: 15px; font-weight: 500;
      text-decoration: none;
      transition: border-color 0.15s, color 0.15s;
    }
    .btn-ghost:hover { border-color: var(--blue-400); color: var(--blue-700); }

    /* FITCHECK */
    .fitcheck-card {
      display: grid; grid-template-columns: 1fr 200px;
      gap: 24px; align-items: center;
      background: linear-gradient(135deg, var(--blue-50) 0%, #EEF3FC 100%);
      border: 1.5px solid var(--blue-200);
      border-radius: 24px; padding: 36px 40px;
      text-decoration: none; color: inherit;
      transition: box-shadow 0.2s, border-color 0.2s;
    }
    .fitcheck-card:hover { border-color: var(--blue-400); box-shadow: 0 8px 32px rgba(37,99,182,0.1); }
    .fc-label {
      font-size: 12px; font-weight: 700; color: var(--blue-700);
      letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 8px;
    }
    .fc-title {
      font-size: 24px; font-weight: 700; color: var(--gray-900);
      letter-spacing: -0.02em; margin: 0 0 10px; line-height: 1.3;
    }
    .fc-desc {
      font-size: 15px; color: var(--gray-600); line-height: 1.75; margin: 0 0 18px;
    }
    .fc-cta {
      display: inline-block;
      background: var(--blue-700); color: #fff;
      padding: 11px 22px; border-radius: 999px;
      font-size: 14px; font-weight: 600;
    }
    .fc-illust { display: flex; justify-content: center; }
    .fc-illust img { max-width: 160px; filter: drop-shadow(0 8px 16px rgba(37,99,182,0.12)); }

    /* SECTION HEAD */
    .section-head {
      display: flex; justify-content: space-between; align-items: baseline;
      margin-bottom: 24px; gap: 16px; flex-wrap: wrap;
    }
    .section-title { font-size: 22px; font-weight: 700; color: var(--gray-900); margin: 0; letter-spacing: -0.01em; }
    .section-sub { font-size: 14px; color: var(--gray-500); margin: 0; }
    .section-more { font-size: 14px; font-weight: 600; color: var(--blue-700); }

    /* PILLAR GRID */
    .pillar-grid {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
    }
    .pillar-grid li { margin: 0; }
    .pillar-grid li.soon { opacity: 0.55; }
    .pillar-card {
      display: block; text-decoration: none; color: inherit;
      background: var(--white); border: 1px solid var(--gray-200);
      border-radius: 18px; overflow: hidden;
      transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    }
    a.pillar-card:hover {
      transform: translateY(-2px);
      border-color: var(--blue-200);
      box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    }
    .pillar-cover { line-height: 0; }
    .pillar-body { padding: 16px 18px 20px; }
    .pillar-en {
      font-size: 11px; font-weight: 700; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--blue-700); margin: 0 0 4px;
    }
    .pillar-label {
      font-size: 18px; font-weight: 700; color: var(--gray-900);
      margin: 0 0 6px; letter-spacing: -0.01em;
    }
    .pillar-desc { font-size: 13px; color: var(--gray-500); line-height: 1.6; margin: 0 0 12px; }
    .pillar-link { font-size: 13px; color: var(--blue-700); font-weight: 600; margin: 0; }
    .pillar-soon { font-size: 12px; color: var(--gray-400); margin: 0; }

    /* ARTICLE ROWS */
    .article-rows { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--gray-200); }
    .row-item { border-bottom: 1px solid var(--gray-200); }
    .row-link {
      display: flex; align-items: center; gap: 16px;
      padding: 18px 4px; text-decoration: none; color: inherit;
      transition: background 0.12s;
    }
    .row-link:hover { background: var(--gray-100); margin: 0 -8px; padding-left: 12px; padding-right: 12px; border-radius: 8px; }
    .row-tag {
      flex-shrink: 0; font-size: 11px; font-weight: 700; color: var(--blue-700);
      background: var(--blue-50); border: 1px solid var(--blue-100);
      padding: 3px 9px; border-radius: 99px; white-space: nowrap;
    }
    .row-body { flex: 1; min-width: 0; }
    .row-title {
      font-size: 15px; font-weight: 600; color: var(--gray-900);
      line-height: 1.5; margin: 0 0 3px; letter-spacing: -0.01em;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .row-desc {
      font-size: 13px; color: var(--gray-500); line-height: 1.5; margin: 0;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .row-arrow { flex-shrink: 0; color: var(--gray-400); font-size: 16px; transition: color 0.12s; }
    .row-link:hover .row-arrow { color: var(--blue-600); }

    /* CROSS LINK */
    .cross-card {
      background: var(--gray-100); border-radius: 20px;
      padding: 36px; text-align: center;
    }
    .cross-label {
      font-size: 11px; color: var(--gray-500); letter-spacing: 0.14em;
      font-weight: 600; text-transform: uppercase; margin: 0 0 8px;
    }
    .cross-card h3 {
      font-size: 20px; font-weight: 700; color: var(--gray-900);
      margin: 0 0 8px; letter-spacing: -0.01em;
    }
    .cross-desc {
      color: var(--gray-600); font-size: 14px; line-height: 1.75;
      margin: 0 auto 20px; max-width: 480px;
    }
    .cross-chips { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; }
    .chip {
      padding: 8px 16px; background: var(--white); color: var(--blue-700);
      border: 1px solid var(--blue-100); border-radius: 999px;
      font-size: 13px; font-weight: 500; text-decoration: none;
      transition: border-color 0.15s, background 0.15s;
    }
    .chip:hover { border-color: var(--blue-300); background: var(--blue-50); }

    /* RESPONSIVE */
    @media (max-width: 960px) {
      .pillar-grid { grid-template-columns: repeat(2, 1fr); }
      .fitcheck-card { grid-template-columns: 1fr; padding: 28px; }
      .fc-illust { display: none; }
    }
    @media (max-width: 600px) {
      .pillar-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
      .hero { padding: 48px 20px 56px; }
      .section-wrap { padding-top: 40px; }
      .row-tag { display: none; }
      .row-title { white-space: normal; }
      .row-desc { display: none; }
    }
    @media (max-width: 420px) {
      .pillar-grid { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
