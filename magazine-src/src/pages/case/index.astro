---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const all = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'case');
const articles = all.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const faqItems = [
  { q: '케이스 스토리는 실제 사례인가요?', a: '동의받은 실제 케이스를 바탕으로 구성했어요. 개인 식별 정보를 보호하기 위해 이름·시점·세부 정보를 각색했습니다.' },
  { q: '내 상황과 비슷한 케이스를 찾고 싶은데 어떻게 하나요?', a: '각 케이스 글의 키워드(임신 주차, 검사명, 거절 사유 등)로 검색하시거나, 태아 pillar의 서브토픽 필터를 활용하시면 관련 정보를 더 빠르게 찾을 수 있어요.' },
  { q: '거절당한 경우 다른 보험사에 신청할 수 있나요?', a: '네, 가능합니다. 보험사마다 심사 기준이 달라서 한 곳에서 거절당해도 다른 곳에서 조건부·표준 가입이 되는 경우가 있어요. 28주 거절 재가입 케이스를 참고하세요.' },
  { q: '케이스 결과를 내 상황에 그대로 적용할 수 있나요?', a: '케이스는 참고 자료이며, 동일한 상황이라도 심사 결과는 보험사·시점·세부 건강 정보에 따라 달라질 수 있어요. 핏체크 진단이나 1:1 상담을 통해 개별 상황을 확인하시는 것을 권장합니다.' },
];

const caseJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: '케이스 스토리 — 실제 태아보험 가입·거절·재가입 사례',
      description: '동의받은 실제 케이스를 바탕으로 재구성한 태아보험 가입·거절·재가입 스토리 모음입니다.',
      url: 'https://villagebaby.kr/magazine/case/',
      publisher: { '@type': 'Organization', name: '베이비빌리', url: 'https://villagebaby.kr/' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '홈', item: 'https://villagebaby.kr/' },
        { '@type': 'ListItem', position: 2, name: '보험 매거진', item: 'https://villagebaby.kr/magazine/' },
        { '@type': 'ListItem', position: 3, name: '케이스', item: 'https://villagebaby.kr/magazine/case/' },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqItems.map(f => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---
<BaseLayout
  title="케이스 스토리 — 실제 태아보험 가입·거절·재가입 사례 | 베이비빌리 보험 매거진"
  description="동의받은 실제 케이스를 바탕으로 재구성한 태아보험 가입·거절·재가입 스토리 모음입니다.">

  <script type="application/ld+json" slot="head" set:html={JSON.stringify(caseJsonLd)} />

  <style is:global>
    main { max-width: none !important; padding: 0 !important; }
  </style>

  <!-- HUB HEADER -->
  <section class="hub-header">
    <div class="inner">
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href="https://villagebaby.kr/">홈</a>
        <span aria-hidden="true">›</span>
        <a href={`${base}`}>매거진</a>
        <span aria-hidden="true">›</span>
        <span class="bc-current">케이스</span>
      </nav>
      <h1>케이스 스토리</h1>
      <p class="hub-intro">
        거절 후 재가입, 조건부 승인, 검사 결과별 대처까지 —<br class="br-pc"/>
        실제 케이스로 배우는 태아보험 가입 전략입니다.
      </p>
    </div>
  </section>

  <!-- ARTICLE LIST -->
  <section class="list-section">
    <div class="inner">
      <h2 class="list-title">케이스 목록 <span class="list-count">{articles.length}편</span></h2>

      {articles.length === 0 ? (
        <p class="empty">케이스 스토리를 준비 중입니다. 곧 첫 케이스를 만나보실 수 있어요.</p>
      ) : (
        <ul class="article-rows">
          {articles.map(a => (
            <li class="row-item">
              <a href={`${base}${a.slug}/`} class="row-link">
                <span class="row-topic">케이스</span>
                <div class="row-body">
                  <p class="row-title">{a.data.title}</p>
                  <p class="row-desc">{a.data.description}</p>
                </div>
                <span class="row-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="inner">
      <h2 class="faq-title">자주 묻는 질문</h2>
      <dl class="faq-list">
        {faqItems.map(f => (
          <div class="faq-item">
            <dt>{f.q}</dt>
            <dd>{f.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- FITCHECK CTA -->
  <section class="cta-section">
    <div class="inner">
      <div class="cta-box">
        <div class="cta-text">
          <p class="cta-label">1:1 상담</p>
          <p class="cta-heading">내 상황과 비슷한 케이스인가요?</p>
          <p class="cta-body">케이스마다 답이 다른 주제는 1:1 상담으로 정리하시는 게 가장 빠릅니다. 카톡으로 편하게 물어보세요.</p>
        </div>
        <a href="https://babybilly.co/insurance/baby/talk/v1?utm_source=magazine&utm_medium=case-hub" class="cta-btn">카톡 무료 상담 →</a>
      </div>
    </div>
  </section>

  <style>
    .inner { max-width: 860px; margin: 0 auto; padding: 0 24px; }

    .hub-header {
      background: linear-gradient(180deg, #FFFBED 0%, #FFFCF5 100%);
      border-bottom: 1px solid var(--gray-100);
      padding: 40px 0 36px;
    }
    .breadcrumb {
      display: flex; align-items: center; gap: 6px;
      font-size: 12px; color: var(--gray-500); margin-bottom: 20px;
    }
    .breadcrumb a { color: var(--gray-500); text-decoration: none; }
    .breadcrumb a:hover { color: var(--blue-700); }
    .bc-current { color: var(--gray-800); font-weight: 600; }
    .hub-header h1 {
      font-size: clamp(26px, 4vw, 36px); font-weight: 700;
      letter-spacing: -0.02em; color: var(--gray-900); margin: 0 0 14px;
    }
    .hub-intro { font-size: 15px; color: var(--gray-600); line-height: 1.8; margin: 0; }
    .br-pc { display: block; }
    @media (max-width: 600px) { .br-pc { display: none; } }

    .list-section { padding: 36px 0 0; }
    .list-title { font-size: 18px; font-weight: 700; color: var(--gray-900); margin: 0 0 20px; }
    .list-count { font-size: 14px; font-weight: 500; color: var(--gray-500); margin-left: 8px; }

    .empty { color: var(--gray-600); padding: 32px; text-align: center; background: var(--gray-100); border-radius: 16px; }

    .article-rows { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--gray-200); }
    .row-item { border-bottom: 1px solid var(--gray-200); }
    .row-link {
      display: flex; align-items: center; gap: 16px;
      padding: 18px 4px; text-decoration: none; color: inherit;
      transition: background 0.12s;
    }
    .row-link:hover { background: var(--gray-100); margin: 0 -8px; padding-left: 12px; padding-right: 12px; border-radius: 8px; }
    .row-topic {
      flex-shrink: 0; font-size: 11px; font-weight: 700;
      color: #8B6914; background: #FFFBED; border: 1px solid #FFE4B5;
      padding: 3px 9px; border-radius: 99px; white-space: nowrap;
    }
    .row-body { flex: 1; min-width: 0; }
    .row-title {
      font-size: 15px; font-weight: 600; color: var(--gray-900);
      line-height: 1.5; margin: 0 0 4px; letter-spacing: -0.01em;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .row-desc {
      font-size: 13px; color: var(--gray-500); line-height: 1.5; margin: 0;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .row-arrow { flex-shrink: 0; color: var(--gray-400); font-size: 16px; transition: color 0.12s; }
    .row-link:hover .row-arrow { color: var(--blue-600); }
    @media (max-width: 560px) {
      .row-topic { display: none; }
      .row-title { white-space: normal; }
      .row-desc { display: none; }
    }

    .faq-section { padding: 48px 0; }
    .faq-title { font-size: 20px; font-weight: 700; color: var(--gray-900); margin: 0 0 24px; }
    .faq-list { display: flex; flex-direction: column; }
    .faq-item { border-bottom: 1px solid var(--gray-200); padding: 18px 0; }
    .faq-item:first-child { border-top: 1px solid var(--gray-200); }
    .faq-item dt { font-size: 15px; font-weight: 600; color: var(--gray-900); margin-bottom: 8px; line-height: 1.5; }
    .faq-item dt::before { content: 'Q. '; color: #8B6914; }
    .faq-item dd { font-size: 14px; color: var(--gray-600); line-height: 1.75; margin: 0; }
    .faq-item dd::before { content: 'A. '; color: var(--gray-400); font-weight: 600; }

    .cta-section { padding: 0 0 64px; }
    .cta-box {
      display: flex; align-items: center; justify-content: space-between; gap: 24px;
      background: linear-gradient(135deg, #8B6914 0%, #6B4F10 100%);
      border-radius: 20px; padding: 32px 36px; flex-wrap: wrap;
    }
    .cta-label { font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.7); letter-spacing: 0.1em; margin: 0 0 6px; }
    .cta-heading { font-size: 18px; font-weight: 700; color: #fff; margin: 0 0 8px; line-height: 1.4; }
    .cta-body { font-size: 13px; color: rgba(255,255,255,0.8); line-height: 1.7; margin: 0; }
    .cta-btn {
      flex-shrink: 0; background: #fff; color: #8B6914;
      font-size: 14px; font-weight: 700;
      padding: 13px 22px; border-radius: 999px;
      text-decoration: none; white-space: nowrap; transition: opacity 0.15s;
    }
    .cta-btn:hover { opacity: 0.92; }
    @media (max-width: 640px) { .cta-box { flex-direction: column; align-items: flex-start; padding: 24px; } }
  </style>
</BaseLayout>
